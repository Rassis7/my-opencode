{
  "$schema": "https://opencode.ai/config.json",
  "tools": {
    "write": true,
    "bash": true,
    "webfetch": true,
    "skill": true
  },
  "plugin": [
    "opencode-skills"
  ],
  "agent": {
    "command-router": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "task": true,
        "todowrite": true
      }
    }
  },
  "mcp": {
    "langchain": {
      "type": "remote",
      "url": "https://docs.langchain.com/mcp"
    },
    "langfuse": {
      "type": "remote",
      "url": "http://localhost:3001/api/public/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Basic cGstbGYtMjVkN2NlMzUtNmM1YS00NzZmLTgxMDgtY2FlNmUyOTg5YjExOnNrLWxmLTRmYTIwY2I5LWUwYjUtNDEyZS1hM2RmLWYwZTA3ZTllZDJjNg=="
      }
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true
    },
    "notion": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "environment": {
        "NOTION_TOKEN": "{env:NOTION_TOKEN}"
      }
    },
    "fetch": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "mcp/fetch"
      ]
    },
    "duckduckgo": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "mcp/duckduckgo"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    }
  },
  "permission": {
    "skill": {
      "*": "allow",
      "pr-review": "allow",
      "internal-*": "allow",
      "experimental-*": "ask"
    }
  }
}